# Tekkai — Variables d'environnement
# Copier en .env pour le dev local

PORT=5006
SECRET_KEY=changeme_generate_with_secrets_token_hex_32

# Compte admin : laisser VIDE en prod → mot de passe aléatoire généré dans les logs.
ADMIN_PASSWORD=
REQUIRE_ADMIN_PASSWORD=0

# Sécurité réseau : derrière nginx/Railway → TRUST_PROXY=1 (IP réelle, anti-spoof XFF).
TRUST_PROXY=0
PROXY_FIX_HOPS=1
CORS_ORIGINS=http://localhost:5006,http://127.0.0.1:5006

# TikFly (RapidAPI)
TIKFLY_KEY=
# ou
RAPIDAPI_KEY=

# LLM (optionnel)
GROQ_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Volume Railway (créé automatiquement)
# RAILWAY_VOLUME_MOUNT_PATH=/app/data
